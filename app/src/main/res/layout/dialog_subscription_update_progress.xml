<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="22dp"
    android:paddingEnd="24dp"
    android:paddingBottom="18dp">

    <TextView
        android:id="@+id/update_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="更新订阅"
        android:textColor="@color/simple_text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/update_dialog_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="准备更新..."
        android:textColor="@color/simple_text_secondary"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="28dp"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="28dp"
                android:layout_height="28dp">

                <TextView
                    android:id="@+id/remote_step_dot"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:background="@drawable/simple_step_dot_bg"
                    android:gravity="center"
                    android:textColor="@color/simple_text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/remote_step_progress"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:indeterminate="true"
                    android:visibility="gone" />

            </FrameLayout>

            <View
                android:layout_width="2dp"
                android:layout_height="54dp"
                android:background="@color/simple_card_stroke" />

            <FrameLayout
                android:layout_width="28dp"
                android:layout_height="28dp">

                <TextView
                    android:id="@+id/local_step_dot"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:background="@drawable/simple_step_dot_bg"
                    android:gravity="center"
                    android:textColor="@color/simple_text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/local_step_progress"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:indeterminate="true"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/remote_step_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="更新远端订阅配置"
                android:textColor="@color/simple_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/remote_step_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="从远程 JSON 获取最新订阅地址"
                android:textColor="@color/simple_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/remote_step_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="等待中"
                android:textColor="@color/simple_text_secondary"
                android:textSize="12sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="22dp" />

            <TextView
                android:id="@+id/local_step_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="拉取本地订阅内容"
                android:textColor="@color/simple_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/local_step_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="使用当前订阅地址更新节点和流量"
                android:textColor="@color/simple_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/local_step_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="等待中"
                android:textColor="@color/simple_text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/update_dialog_close"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="22dp"
        android:enabled="false"
        android:gravity="center"
        android:text="关闭"
        android:textColor="@color/simple_text_primary"
        app:backgroundTint="@color/simple_button_idle"
        app:cornerRadius="22dp" />

</LinearLayout>
